{
    "build": { "dockerfile": "Dockerfile" },
        "features": {
        "ghcr.io/devcontainer-community/devcontainer-features/starship.rs:1":{}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "streetsidesoftware.code-spell-checker",
                "streetsidesoftware.code-spell-checker-british-english",
                "streetsidesoftware.code-spell-checker-british-english-ise",
                "yzhang.markdown-all-in-one"
            ]
        }
    },
    "runArgs": ["--network=host"],
    "initializeCommand": "mkdir -p $HOME/.config/opencode",
    "postCreateCommand": "echo 'eval $(starship init bash)' >> /home/vscode/.bashrc",
    "features": {
        "ghcr.io/devcontainer-community/devcontainer-features/starship.rs:1":{}
    },
    "mounts": [
        "source=${localEnv:HOME}/.config/opencode,target=/home/vscode/.config/opencode,type=bind,consistency=cached"
    ]
}